{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build:emulator": "node scripts/build-emulator-bundle.mjs",
    "vendor:emulator": "node scripts/vendor-emulator.mjs",
    "dev": "npm run build:emulator && vite",
    "build": "npm run build:emulator && tsc -b && vite build",
    "build:watch": "VITE_WATCH_BUILD=1 vite build --watch",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "typecheck": "tsc -b",
    "lint": "eslint src e2e"
  },
  "dependencies": {
    "@ant-design/icons": "^6.0.0",
    "@ant-design/v5-patch-for-react-19": "^1.0.3",
    "@tanstack/react-query": "^5.90.2",
    "antd": "^5.25.0",
    "dompurify": "^3.4.5",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^22.19.19",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "jsdom": "^26.1.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^6.3.5",
    "vitest": "^3.2.4"
  }
}
