# Dev environment for docker compose (backend service).
# Copy to build/dev/.env via: make setup
#
# Precedence: defaults → YAML (CONFIG_PATH) → env (env wins).

CONFIG_PATH=build/dev/config.yaml

# ENV=development
# STORAGE_DIR=storage
# STORAGE_URL=https://github.com/top4ek/retro_files
# SERVER_PORT=8080
# DATABASE_DSN=:memory:
# SYNC_INTERVAL_HOURS=0
#
# database.driver is YAML-only (default: sqlite3).
