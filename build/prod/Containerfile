FROM node:26-alpine@sha256:e88a35be04478413b7c71c455cd9865de9b9360e1f43456be5951032d7ac1a66 AS frontend-builder
WORKDIR /app
COPY frontend/package*.json ./
RUN npm ci
COPY frontend/ .
RUN npm run build

FROM golang:1.26.5-alpine@sha256:0178a641fbb4858c5f1b48e34bdaabe0350a330a1b1149aabd498d0699ff5fb2 AS backend-builder
WORKDIR /app
RUN apk add --no-cache gcc musl-dev git

ENV GO111MODULE=on
ENV CGO_ENABLED=1
ENV GOOS=linux

ARG GIT_COMMIT=unknown
ENV GIT_COMMIT=${GIT_COMMIT}

COPY go.mod go.sum ./
RUN go mod download

COPY . .
COPY --from=frontend-builder /app/dist ./frontend/dist

RUN go build -tags sqlite_fts5 -ldflags "-X main.version=${GIT_COMMIT}" -o /app/server ./cmd/server/main.go

FROM alpine:3.24@sha256:28bd5fe8b56d1bd048e5babf5b10710ebe0bae67db86916198a6eec434943f8b
WORKDIR /app

ARG GIT_COMMIT=unknown

# git stays: the sync worker clones/pulls the storage repository at runtime.
RUN apk add --no-cache tzdata ca-certificates git sqlite wget

COPY --from=backend-builder /app/server .
COPY --from=backend-builder /app/frontend/dist ./frontend/dist

RUN mkdir -p storage data && \
    adduser -D -u 10001 app && \
    chown -R app:app /app

USER app

LABEL org.opencontainers.image.revision="${GIT_COMMIT}"

EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=5s --retries=3 --start-period=15s \
  CMD wget -q -O /dev/null http://127.0.0.1:8080/ping || exit 1

CMD ["./server"]
